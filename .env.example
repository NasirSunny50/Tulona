# Copy to .env and adjust
POSTGRES_USER=tulona
POSTGRES_PASSWORD=tulona
POSTGRES_DB=tulona
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

DATABASE_URL=postgresql://tulona:tulona@localhost:5432/tulona

# Scraper politeness
SCRAPE_DELAY_SECONDS=2
SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; TulonaBot/0.1; +https://tulona.local)

# Scheduler (24h clock)
REFRESH_HOURS=12,15,18,21
DISCOVERY_HOUR=3
TIMEZONE=Asia/Dhaka
